# Supabase project URL (from Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (used by public site reads + auth client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Toggle public maintenance mode. Set to true to redirect public pages to /maintenance.
NEXT_PUBLIC_MAINTENANCE_MODE=false

# Supabase service role key (server-only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional storage bucket for CMS assets
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=cms-assets

# Gmail SMTP sender account (no browser exposure; server-side only)
GMAIL_USER=

# Gmail App Password (16-char app password, not your regular Gmail password)
GMAIL_APP_PASSWORD=

# Inbox that receives website inquiries
CONTACT_TO_EMAIL=

# Friendly sender label used in outbound inquiry emails
CONTACT_FROM_NAME=1Hala Website
